      "hizb": 1,
      "manzil": 1,
      "page": 1,
      "sajdah": false,
      "translation_bn": "আমরা কেবল আপনারই ইবাদত করি এবং একমাত্র আপনারই সাহায্য প্রার্থনা করি।"
    },
