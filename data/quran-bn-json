      "ruku": 1,
      "hizb": 1,
      "manzil": 1,
      "page": 1,
      "sajdah": false,
      "translation_bn": "আমাদেরকে সরল ও সঠিক পথের দিশা দিন।"
    },
    {
      "ayah": 7,
      "juz": 1,
      "ruku": 1,
      "hizb": 1,
      "manzil": 1,
      "page": 1,
      "sajdah": false,
      "translation_bn": "সেইসব মানুষের পথ, যাদের প্রতি আপনি অনুগ্রহ করেছেন; তাদের পথ নয়, যারা আপনার ক্রোধের সম্মুখীন হয়েছে এবং নয় তাদের পথ, যারা সত্যপথ থেকে বিচ্যুত হয়েছে।"
